{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Interactive PowerShell - SampleCmdlet Testing",
            "type": "PowerShell",
            "request": "launch",
            "preLaunchTask": "build",
            "cwd": "${workspaceFolder}",
            "script": "Import-Module -Name '${workspaceFolder}/tests/SampleCmdlet/bin/Debug/net10.0/SampleCmdlet.dll'; $Host.EnterNestedPrompt()",
            "attachDotnetDebugger": true,
            "createTemporaryIntegratedConsole": true,
        }
    ]
}

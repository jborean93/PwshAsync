{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Interactive PowerShell - SampleCmdlet Testing",
            "type": "PowerShell",
            "request": "launch",
            "preLaunchTask": "build",
            "cwd": "${workspaceFolder}",
            "script": "${workspaceFolder}/tools/LaunchScript.ps1 -NoExit",
            "attachDotnetDebugger": true,
            "createTemporaryIntegratedConsole": true,
        }
    ]
}
